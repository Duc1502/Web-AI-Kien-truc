# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# --- Supabase (đăng nhập Google + gói credit) ---
# Dùng chung 1 Supabase project với Backend/admin (xem Backend/README.md).
# VITE_* được bundle vào client (browser) — chỉ chứa key công khai (anon).
VITE_SUPABASE_URL="https://xxxx.supabase.co"
VITE_SUPABASE_ANON_KEY="MY_SUPABASE_ANON_KEY"

# SUPABASE_SERVICE_ROLE_KEY: KHÔNG bao giờ thêm tiền tố VITE_ — chỉ server.ts (Node) được đọc,
# dùng để ghi bảng transactions (client không có quyền INSERT trực tiếp).
SUPABASE_URL="https://xxxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="MY_SUPABASE_SERVICE_ROLE_KEY"
